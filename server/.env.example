# --- TMDB credentials (get a free account at https://www.themoviedb.org) ---
# You only need ONE of the two. The v4 Read Access Token is recommended.
#
# Settings → API → "API Read Access Token" (a long eyJ... JWT):
TMDB_BEARER=
#
# ...or the classic v3 "API Key":
TMDB_API_KEY=

# Port the server listens on (frontend is served from the same origin in local dev)
PORT=8787

# --- Split deployment (frontend on Vercel, backend on Render) ---
# Comma-separated list of frontend origins allowed to call this API with cookies.
# Required when the frontend is hosted on a different origin than this backend.
# Defaults to https://stredio.vercel.app if unset.
CORS_ORIGINS=https://stredio.vercel.app

# Set to 1 when running behind a proxy/load balancer (e.g. Render) so the per-IP
# rate limiter reads the real client IP from X-Forwarded-For.
TRUST_PROXY=1

# --- Media stream proxy (Cloudflare Worker) ---
# Offloads the video byte-proxy off this origin so playback bandwidth never
# touches the (metered, free-tier-capped) host. Point at the deployed Worker
# (cloudflare-worker/stream-worker.js). When set, mapStream() rewrites gated /
# HLS streams to <base>/stream-proxy and the Worker streams the bytes (Cloudflare
# does not meter Worker bandwidth). The Worker origin is also auto-added to the
# CSP connect-src so hls.js can fetch from it. Leave UNSET for local dev to use
# the same-origin Express /api/stream-proxy instead.
STREAM_PROXY_BASE=https://stredio-stream.shonomusicofficial.workers.dev

# --- Persistent storage (Neon Postgres) ---
# Render's filesystem is EPHEMERAL — without this, all accounts/sessions/settings
# are wiped on every restart or redeploy. Set DATABASE_URL to a Neon (or any
# Postgres) connection string and the server stores every JSON document in a
# single `kv` table that survives restarts. Leave UNSET for local dev to keep
# using plain JSON files under server/data/.
# Get a free, persistent database at https://neon.tech (no card required), then
# copy its "pooled" connection string here (must allow SSL).
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
